# Скопируйте в .env и подставьте значения. .env НЕ коммитим в git.
#
# Провайдер выбирается сам: если задан GEMINI_API_KEY — используется Gemini,
# иначе ANTHROPIC_API_KEY — Claude. Можно задать явно: AI_PROVIDER=gemini | claude

# --- Вариант 1: Gemini (бесплатный, ключ без карты) ---
# Получить: https://aistudio.google.com  →  Get API key
GEMINI_API_KEY=
# Модель (необязательно):
GEMINI_MODEL=gemini-2.0-flash

# --- Вариант 2: YandexGPT (Yandex Cloud) ---
# Нужны API-ключ сервисного аккаунта и ID каталога. Консоль: https://console.yandex.cloud
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite/latest
# Чтобы точно выбрался Яндекс, задайте AI_PROVIDER=yandex

# --- Вариант 3: Claude (платный) ---
# Получить: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Общее ---
# Общий секрет приложения (необязательно). Тот же токен впишите в приложении.
APP_SHARED_TOKEN=
# Явно выбрать провайдера (необязательно): gemini | claude
# AI_PROVIDER=gemini
# Порт (необязательно)
PORT=8787
