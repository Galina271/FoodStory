# Скопируйте в .env и подставьте свои значения. .env НЕ коммитим в git.

# Ключ Anthropic (обязательно). Получить: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Модель Claude (необязательно). Дешевле: claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-8

# Общий секрет приложения (необязательно, но желательно для публичного сервера).
# Такой же токен пропишите в приложении (Настройки → сервер).
APP_SHARED_TOKEN=

# Порт (необязательно)
PORT=8787
